[Unit]
Description=SilverHand arm control (%i)

[Service]
Type=simple
WorkingDirectory=%h/silver_ws
Environment=ROS_WS=%h/silver_ws
Environment=ROS_DISTRO=jazzy
Environment=AMENT_TRACE_SETUP_FILES=
ExecStart=%h/silver_ws/src/silverhand_arm_control/scripts/start_arm_%i.sh
Restart=on-failure
RestartSec=2
KillSignal=SIGINT
TimeoutStopSec=15

[Install]
WantedBy=default.target
